# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Discord bot token (from Discord Developer Portal)
DISCORD_TOKEN=your-bot-token-here

# Must match NHL_BOT_SECRET set when starting the Flask server
NHL_BOT_SECRET=change-me-to-a-strong-secret

# Flask server URL (internal — bot talks to this)
API_BASE=http://localhost:3001

# Public-facing URL shown in Discord links (update once your server is public)
APP_URL=http://localhost:3001

# Fill these in once the bot is in the server (right-click → Copy ID with Developer Mode on)
GUILD_ID=
SCORES_CHANNEL=
TRADES_CHANNEL=
PENDING_CHANNEL=

# Discord role ID for admins (approve/reject scores, use /trade, /pending)
# Leave blank = anyone can use admin commands (password is the only gate)
ADMIN_ROLE_ID=

# Power rankings (weekly AI post)
# Get a free Groq API key at console.groq.com — no credit card needed
GROQ_API_KEY=
POWER_RANKINGS_CHANNEL=   # Channel ID to post weekly rankings
POWER_RANKINGS_DAY=0      # Weekday: 0=Mon 1=Tue 2=Wed 3=Thu 4=Fri 5=Sat 6=Sun
POWER_RANKINGS_HOUR=13    # UTC hour to post (13 = 9am Eastern)
